    "@rainbow-me/rainbowkit": "^2.2.4",
    "@tanstack/react-query": "^5.62.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vercel/node": "^3.2.29",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
