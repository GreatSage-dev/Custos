{
  "version": 2,
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/approve",
      "destination": "/api/approve"
    },
    {
      "source": "/((?!api|health|approve).*)" ,
      "destination": "/index.html"
    }
  ]
}
